import { NextResponse } from "next/server";
import { getBaseProvider, getEpochManager } from "../../../lib/epoch-manager";

export const dynamic = "force-dynamic";

export async function GET() {
  try {
    const provider = getBaseProvider();
    const E = getEpochManager(provider);

    const latest = await provider.getBlockNumber();
    const fromBlock = Math.max(0, latest - 300000);

    const events = await Promise.all([
      E.queryFilter(E.filters.ProofSubmitted(), fromBlock, latest),
      E.queryFilter(E.filters.ProofScored(), fromBlock, latest),
      E.queryFilter(E.filters.EpochOpened(), fromBlock, latest),
      E.queryFilter(E.filters.EpochClosed(), fromBlock, latest),
    ]);

    const flat = events.flat();

    const rows = flat
      .map((ev: any) => ({
        type: ev.event,
        block: ev.blockNumber,
        tx: ev.transactionHash,
        args: Object.fromEntries(
          Object.entries(ev.args || {}).filter(([k]) => isNaN(Number(k)))
        ),
      }))
      .sort((a, b) => b.block - a.block)
      .slice(0, 50);

    return NextResponse.json({ ok: true, rows });
  } catch (e: any) {
    return NextResponse.json({ ok: false, error: e?.message });
  }
}